{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Arma3 Session Bridge",
  "version": "0.1.0",
  "identifier": "cloud.ralle1976.arma3-session-bridge",

  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },

  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "productName": "Arma3 Session Bridge",
    "identifier": "cloud.ralle1976.arma3-session-bridge",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "nsis": {
      "installMode": "perMachine",
      "license": "../LICENSE.txt",
      "preinstallSection": "!include \"nsis\\hooks.nsh\"\n!insertmacro customInstall",
      "startMenuFolder": "Arma3 Session Bridge",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "resources": {}
  },

  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Arma 3 Session Bridge",
        "width": 900,
        "height": 650,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'"
    },
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/icon.ico",
      "iconAsTemplate": false,
      "menuOnLeftClick": false
    }
  }
}
